#: admin/feedback/deactivation-feedback-form.php:9
msgid "We’re sorry to see you go! 💔"
msgstr "നിങ്ങളെ പോയി പോകുന്നത് കാണാൻ ഞങ്ങൾ ദു:ഖിതരാണ്! 💔"

#: admin/feedback/deactivation-feedback-form.php:11
msgid "Close"
msgstr "അടയ്ക്കുക"

#: admin/feedback/deactivation-feedback-form.php:15
msgid ""
"Can you please tell us why you’re deactivating the plugin? Your feedback "
"helps us make it better."
msgstr ""
"നിങ്ങൾ പ്ലഗിൻ അപ്രവർത്തനം ചെയ്യുന്നതിന് കാരണം പറയാമോ? നിങ്ങളുടെ അഭിപ്രായം "
"ഞങ്ങളെ അത് മെച്ചപ്പെടുത്താൻ സഹായിക്കുന്നു."

#: admin/feedback/deactivation-feedback-form.php:19
msgid "Temporary deactivation (troubleshooting)"
msgstr "താൽക്കാലിക അപ്രവർത്തനം (പ്രശ്നപരിഹാരം)"

#: admin/feedback/deactivation-feedback-form.php:23
msgid "Compatibility issue"
msgstr "സമന്വയ പ്രശ്നം"

#: admin/feedback/deactivation-feedback-form.php:25
msgid "Please describe what part of the layout or functionality was affected."
msgstr ""
"ലേഔട്ടിന്റെ അല്ലെങ്കിൽ പ്രവർത്തനത്തിന്റെ ഏത് ഭാഗം ബാധിതമായെന്ന് ദയവായി "
"വിശദീകരിക്കുക."

#: admin/feedback/deactivation-feedback-form.php:30
msgid "Difficult to set up"
msgstr "സജ്ജീകരിക്കാൻ ബുദ്ധിമുട്ട്"

#: admin/feedback/deactivation-feedback-form.php:32
msgid "What part of the setup was confusing or unclear?"
msgstr "സജ്ജീകരണത്തിന്റെ ഏത് ഭാഗം ആശങ്കാജനകമായിരുന്നു?"

#: admin/feedback/deactivation-feedback-form.php:37
msgid "Missing features"
msgstr "അനുവദിച്ച ഫീച്ചറുകൾ നഷ്ടമായത്"

#: admin/feedback/deactivation-feedback-form.php:39
msgid "Which features were you looking for?"
msgstr "നിങ്ങൾ ഏത് ഫീച്ചറുകൾക്കായി നോക്കുകയായിരുന്നു?"

#: admin/feedback/deactivation-feedback-form.php:44
msgid "Other"
msgstr "മറ്റു"

#: admin/feedback/deactivation-feedback-form.php:46
msgid ""
"Please share why you’re deactivating the Google Business Reviews plugin so "
"we can make improvements."
msgstr ""
"ദയവായി നിങ്ങൾ Google ബിസിനസ് റിവ്യൂസ് പ്ലഗിൻ അപ്രവർത്തനത്തിലാക്കുന്നതിന്റെ "
"കാരണം പങ്കുവെക്കുക, അതിനാൽ ഞങ്ങൾ മെച്ചപ്പെടുത്തലുകൾ നടത്താൻ കഴിയും."

#: admin/feedback/deactivation-feedback-form.php:58
msgid ""
"Your privacy is important to us. No personal data is collected with this "
"form—just your valuable feedback and basic system information (such as "
"WordPress and plugin versions) to help us improve our plugin."
